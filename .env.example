# claude_freelance - Environment Configuration
# Multi-platform freelance proposal optimizer powered by Claude API

# Application
APP_NAME="Freelance Proposal Optimizer"
APP_ENV=production
APP_URL=https://freelance.visionquest2020.net
# Note: Code uses DB_NAME, DB_USER, DB_PASSWORD (not DB_DATABASE/DB_USERNAME)
APP_PATH=""
APP_DEBUG=false

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=freelance
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# Anthropic API
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# App Settings
ERROR_EMAIL=email4johnson@gmail.com
FIT_SCORE_THRESHOLD=5

# Error Reporting (production)
ERROR_REPORTING=0
DISPLAY_ERRORS=0
